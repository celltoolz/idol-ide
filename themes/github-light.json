{
  "name": "GitHub Light",
  "description": "GitHub Light — white background with GitHub's red/purple/blue syntax palette.",
  "kind": "light",
  "palette": {
    "bg":               "#ffffff",
    "fg":               "#24292e",
    "caret":            "#24292e",
    "select_bg":        "#c8d1da",
    "current_line_bg":  "#f6f8fa",
    "guide":            "#e1e4e8",
    "guide_active":     "#babbbd",
    "gutter_bg":        "#fafbfc",
    "gutter_fg":        "#babbbd",
    "gutter_fg_active": "#24292e",
    "bracket_match":    "#babbbd",
    "word_occurrence":  "#dbe9f9",
    "fold_dots":        "#babbbd",
    "sticky_bg":        "#f6f8fa",
    "sticky_border":    "#e1e4e8",
    "diag_error":       "#cb2431",
    "diag_warning":     "#b08800",
    "diag_info":        "#0366d6",
    "find_match":       "#fff3b4",
    "find_current":     "#ffd33d",
    "minimap_bg":       "#f6f8fa",
    "minimap_viewport": "#e1e4e8"
  },
  "tokens": {
    "comment":      {"color": "#6a737d", "italic": true},
    "string":       {"color": "#032f62"},
    "number":       {"color": "#005cc5"},
    "keyword_flow": {"color": "#d73a49"},
    "keyword_decl": {"color": "#d73a49"},
    "constant":     {"color": "#005cc5"},
    "self_cls":     {"color": "#e36209"},
    "type":         {"color": "#6f42c1"},
    "function":     {"color": "#6f42c1"},
    "method":       {"color": "#6f42c1"},
    "decorator":    {"color": "#6f42c1"},
    "parameter":    {"color": "#24292e"},
    "diff_add":     {"color": "#22863a"},
    "diff_remove":  {"color": "#b31d28"},
    "diff_hunk":    {"color": "#0366d6"},
    "diff_meta":    {"color": "#6a737d"}
  }
}
